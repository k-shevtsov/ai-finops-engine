CPU_PRICE_PER_CORE_HOUR=0.048
MEMORY_PRICE_PER_GB_HOUR=0.006
MAX_RECOMMENDATIONS_PER_HOUR=10
EXCLUDED_NAMESPACES=kube-system,monitoring,argocd
